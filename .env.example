# TiDB Cloud (MySQL compatible) — get from TiDB Console → Connect
DATABASE_URL="mysql://user:password@host:4000/database?sslaccept=strict"

# Site
NEXT_PUBLIC_SITE_URL="https://iowajournalist.org"

# Admin login password
ADMIN_PASSWORD="change-me-strong-password"

# Secret for signing admin session cookies (32+ chars)
ADMIN_SECRET="change-me-random-secret-at-least-32-chars"

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Protect cron endpoints
CRON_SECRET="change-me-cron-secret"

# Auto-publish Gemini drafts without manual review (true/false)
AUTO_PUBLISH_GEMINI="false"
